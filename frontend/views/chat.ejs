<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>LegalAssist AI – Chat</title>
  <meta name="description" content="Chat with LegalAssist AI for plain-language legal explanations." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;1,400&family=IBM+Plex+Mono:wght@400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="bg-orb orb-1"></div>
  <div class="bg-orb orb-2"></div>

  <div class="app-shell">
    <!-- ── Sidebar ── -->
    <aside class="sidebar stagger stagger-1">
      <div class="brand-block">
        <div class="brand-logo">
          <div class="brand-icon">⚖️</div>
          <div>
            <h1>LegalAssist AI</h1>
          </div>
        </div>
        <p>Plain-language legal guidance</p>
      </div>

      <button id="newChatBtn" class="btn btn-primary" type="button">
        + New Chat
      </button>

      <section class="chat-list-wrap">
        <h2>Recent Chats</h2>
        <div id="chatList" class="chat-list"></div>
      </section>
    </aside>

    <!-- ── Chat Panel ── -->
    <main class="chat-panel stagger stagger-2">
      <header class="topbar stagger stagger-3">
        <div class="topbar-left">
          <h2 id="chatTitle">New conversation</h2>
          <p class="topbar-subtitle">Ask legal questions in plain English. Press Enter to send.</p>
        </div>
        <div class="topbar-actions">
          <button id="themeToggle" class="theme-toggle" type="button" aria-label="Switch to dark mode" title="Switch theme">
            <span class="theme-icon sun" aria-hidden="true"></span>
            <span class="theme-icon moon" aria-hidden="true"></span>
          </button>
          <button id="authBtn" class="btn btn-accent" type="button">Login</button>
        </div>
      </header>

      <section id="chatMessages" class="chat-messages stagger stagger-4"></section>

      <section class="composer-wrap stagger stagger-5">
        <div id="pendingUploads" class="pending-uploads"></div>

        <div class="composer-input-row">
          <textarea
            id="questionInput"
            rows="1"
            placeholder="Ask a legal question… (Shift+Enter for new line)"
          ></textarea>
          <div class="composer-actions">
            <label class="upload-label" for="fileInput" title="Attach files">📎</label>
            <input id="fileInput" type="file" accept="image/*,.pdf,.doc,.docx,.txt" multiple />
            <button id="sendBtn" class="btn btn-primary" type="button" title="Send (Enter)">
              <span class="send-icon">➤</span>
            </button>
          </div>
        </div>

        <div class="composer-hint">
          Press <kbd>Enter</kbd> to send &nbsp;·&nbsp; <kbd>Shift+Enter</kbd> for new line &nbsp;·&nbsp; Attach up to 5 files
        </div>
      </section>
    </main>
  </div>

  <script>
    window.APP_CONFIG = <%- JSON.stringify(config) %>;
  </script>
  <!-- marked.js for Markdown rendering -->
  <script src="https://cdn.jsdelivr.net/npm/marked@9/marked.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
