<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>LegalAssist AI Chat</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="bg-orb orb-1"></div>
  <div class="bg-orb orb-2"></div>

  <div class="app-shell">
    <aside class="sidebar stagger stagger-1">
      <div class="brand-block">
        <h1>LegalAssist AI</h1>
        <p>Legal answers in clear language</p>
      </div>

      <button id="newChatBtn" class="btn btn-primary" type="button">+ New Chat</button>

      <section class="chat-list-wrap">
        <h2>Recent Chats</h2>
        <div id="chatList" class="chat-list"></div>
      </section>
    </aside>

    <main class="chat-panel stagger stagger-2">
      <header class="topbar stagger stagger-3">
        <div>
          <h2 id="chatTitle">New conversation</h2>
          <p>Ask legal questions in plain English.</p>
        </div>
        <div class="topbar-actions">
          <button id="themeToggle" class="theme-toggle" type="button" aria-label="Switch to dark mode" title="Switch theme">
            <span class="theme-icon sun" aria-hidden="true"></span>
            <span class="theme-icon moon" aria-hidden="true"></span>
          </button>
          <button id="authBtn" class="btn btn-accent" type="button">Login</button>
        </div>
      </header>

      <section id="chatMessages" class="chat-messages stagger stagger-4"></section>

      <section class="composer-wrap stagger stagger-5">
        <div id="pendingUploads" class="pending-uploads"></div>
        <div class="composer-row">
          <label class="upload-btn" for="fileInput">Upload</label>
          <input id="fileInput" type="file" accept="image/*,.pdf,.doc,.docx,.txt" multiple />
          <textarea id="questionInput" rows="1" placeholder="Type your legal question..."></textarea>
          <button id="sendBtn" class="btn btn-primary" type="button">Send</button>
        </div>
      </section>
    </main>
  </div>

  <script>
    window.APP_CONFIG = <%- JSON.stringify(config) %>;
  </script>
  <script src="/js/app.js"></script>
</body>
</html>
